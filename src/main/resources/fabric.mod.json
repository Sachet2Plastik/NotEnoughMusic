{
	"schemaVersion": 1,
	"id": "notenoughmusic",
	"version": "${version}",
	"name": "Not Enough Music",
	"description": "This mod add more music discs to collect and listen to and more way to obtain them making the collecting process more entertaining",
	"authors": [
		"Sachet2Plastik"
	],
	"contact": {
		"homepage": "",
		"sources": "https://github.com/Sachet2Plastik/NotEnoughMusic"
	},
	"license": "MIT",
	"icon": "assets/notenoughmusic/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"sachet2plastik.notenoughmusic.NotEnoughMusic"
		],
		"client": [
			"sachet2plastik.notenoughmusic.NotEnoughMusicClient"
		]
	},
	"mixins": [
		"notenoughmusic.mixins.json",
		{
			"config": "notenoughmusic.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}